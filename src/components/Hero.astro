---
import KubernetesScene from './KubernetesScene.tsx';
---
<section class="relative min-h-screen flex flex-col items-center justify-center gap-8 px-6 text-center">
  <div class="max-w-2xl space-y-4">
    <h1 class="text-5xl sm:text-7xl font-bold tracking-tight">sm-ard</h1>
    <p class="text-lg sm:text-xl text-neutral-300">
      <span class="font-semibold text-neutral-100">Senior Platform Engineer</span>
      · multi-cloud · Kubernetes · AI-native
    </p>
    <p class="text-neutral-400">
      I build reliable infrastructure and apply LLMs to operations problems.
    </p>
  </div>

  <div
    class="w-full max-w-3xl h-[360px] rounded-xl border border-neutral-800 bg-neutral-900/40 overflow-hidden"
    aria-label="Interactive 3D Kubernetes cluster visualization"
  >
    <KubernetesScene client:visible />
  </div>
</section>
